# NextAuth v5 (Auth.js)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0)
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Vercel Blob (Vercel dashboard → Storage → Create → Blob)
BLOB_READ_WRITE_TOKEN=

# Comma-separated list of allowed email domains
ALLOWED_EMAIL_DOMAINS=scalyng.com,betterdatatoday.com

# Auth.js base URL (set automatically by Vercel via VERCEL_URL; only set locally)
# AUTH_URL=http://localhost:3000
